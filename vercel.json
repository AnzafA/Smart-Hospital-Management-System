{
    "buildCommand": "cd backend && npm install && cd ..",
    "experimentalServices": {
        "frontend": {
            "framework": "static",
            "routePrefix": "/",
            "source": "frontend"
        },
        "backend": {
            "entrypoint": "backend/server.js",
            "routePrefix": "/_/backend",
            "runtime": "nodejs20.x"
        }
    }
}

